function renderMessages(msgs,conv){
  const el=document.getElementById('messages');
  el.innerHTML=msgs.map(m=>{
    if(m.type==='day') return `<div class="day-sep"><span>${m.label}</span></div>`;
    if(m.type==='sentby') return `<div class="sent-by">${m.label}</div>`;
    if(m.type==='me') return `<div class="msg-bubble me">${m.text.replace(/\n/g,'<br>')}</div>`;
    if(m.type==='them'){
      const avatarH=conv.img?`<img src="${conv.img}" style="width:30px;height:30px;border-radius:50%;flex-shrink:0">`:`<div style="width:30px;height:30px;border-radius:50%;background:${conv.color||getColor(conv.name)};display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;color:#fff;flex-shrink:0">${conv.initials||getInitials(conv.name)}</div>`;
