(function initImgPicker(){
  const grid=document.getElementById('img-picker-grid');
  grid.innerHTML=phoneProducts.map((p,i)=>`
    <div class="img-picker-item" data-index="${i}">
      <img src="${p.img}" alt="${p.name}" loading="lazy"/>
      <div class="pname">${p.name}</div>
    </div>`).join('');
  // Use event delegation on grid to ensure clicks on child elements (img, pname) work
  grid.addEventListener('click',function(e){
    e.stopPropagation();
    const item=e.target.closest('.img-picker-item');
    if(item){
      const idx=parseInt(item.dataset.index,10);
      if(!isNaN(idx)) sendProductImage(idx);
    }
  });
})();

function toggleImgPicker(e){
  e.stopPropagation();
  const popup=document.getElementById('img-picker-popup');
  const isOpen=popup.classList.contains('open');
  if(!isOpen){
    const btn=document.getElementById('img-picker-btn');
    const r=btn.getBoundingClientRect();
    // First make popup visible but hidden to measure its real height
    popup.style.visibility='hidden';
    popup.style.top='0px';
    popup.style.left='0px';
    popup.classList.add('open');
    const h=popup.offsetHeight;
    const w=popup.offsetWidth;
    // Now position it above the button
    popup.style.left=Math.max(8,r.left-10)+'px';
    popup.style.top=(r.top-h-12)+'px';
    popup.style.visibility='';
  } else {
    popup.classList.remove('open');
  }
}

function sendProductImage(index){
  const p=phoneProducts[index];
  const msgs=document.getElementById('messages');
  // Close the picker popup
  document.getElementById('img-picker-popup').classList.remove('open');
  // Create image message bubble
  const bubble=document.createElement('div');
  bubble.className='msg-img-bubble';
  const img=new Image();
  img.src=p.img;
  img.alt=p.name;
  img.style.width='220px';
  img.style.height='165px';
  img.style.objectFit='cover';
  img.style.display='block';
  const caption=document.createElement('div');
  caption.className='img-caption';
  caption.textContent='📱 '+p.name;
  bubble.appendChild(img);
  bubble.appendChild(caption);
  msgs.appendChild(bubble);
  // Scroll to bottom to show the new image
  setTimeout(()=>msgs.scrollTo({top:msgs.scrollHeight,behavior:'smooth'}),100);
}

// close picker when clicking outside
document.addEventListener('click',function(e){
  const popup=document.getElementById('img-picker-popup');
  const btn=document.getElementById('img-picker-btn');
  if(popup && !popup.contains(e.target) && e.target!==btn && !btn.contains(e.target)){
    popup.classList.remove('open');
  }
});

