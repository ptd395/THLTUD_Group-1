function generateCustomerData(conv){
  const h=hash(conv.name);
  const firstName=conv.name.split(' ')[0].toLowerCase().replace(/[^a-z]/g,'');
  const lastName=conv.name.split(' ').slice(-1)[0].toLowerCase().replace(/[^a-z]/g,'');
  const company=companies[h%companies.length];
  const city=cities[(h>>2)%cities.length];
  const phoneNum=`+1 (555) ${String((h%900)+100)}-${String((h>>4)%9000+1000)}`;
  const email=`${firstName}.${lastName}@${company.toLowerCase().replace(/[^a-z]/g,'').substring(0,8)}.io`;
  const tagPair=tags[h%tags.length];
  const acts=activities[h%activities.length];
  return{company,city,phone:phoneNum,email,tags:tagPair,acts};
}

function updateRightPanel(conv){
  const d=generateCustomerData(conv);
  // avatar
  const rpAv=document.getElementById('rp-avatar');
  rpAv.textContent=conv.initials||getInitials(conv.name);
  rpAv.style.background=conv.color||getColor(conv.name);
  // name / company
  document.getElementById('rp-name').textContent=conv.name;
  document.getElementById('rp-company').textContent=d.company;
  // tags
  document.getElementById('rp-tags').innerHTML=d.tags.map(t=>`<span class="tag ${tagColorMap[t]||'prospect'}">${t}</span>`).join('');
  // contact
  document.getElementById('rp-contact').innerHTML=`
    <div class="contact-row"><div class="val">${d.email}</div><div class="lbl">Email</div></div>
    <div class="contact-row"><div class="val">${d.phone}</div><div class="lbl">Phone</div></div>
    <div class="contact-row"><div class="val">${d.city}</div><div class="lbl">Location</div></div>`;
  // activity
  const dotClasses=['','gray','gray'];
  const actItems=[];
  for(let i=0;i<d.acts.length;i+=2){
    actItems.push(`<div class="activity-item"><div class="act-dot ${dotClasses[i/2]||'gray'}"></div><div class="act-text"><div class="name">${d.acts[i]}</div><div class="when">${d.acts[i+1]}</div></div></div>`);
  }
  document.getElementById('rp-activity').innerHTML=actItems.join('');
}

function selectConv(id){
  const allLists=Object.values(conversations).flat();
  const conv=allLists.find(c=>c.id===id);
  if(!conv)return;
  activeConvId=id;
  document.querySelectorAll('.conv-item').forEach(el=>el.classList.remove('active'));
  const item=document.getElementById('ci-'+id);
  if(item) item.classList.add('active');
  updateChatHeader(conv);
  renderMessages(genMessages(conv),conv);
  updateRightPanel(conv);
  // update reply placeholder
  const placeholders={whatsapp:'WhatsApp',email:'Email',messenger:'Messenger',website:'Website'};
  document.getElementById('reply-textarea').placeholder=`Type your reply via ${placeholders[conv.ch]||''}...`;
  // highlight matching reply tab
  const map={whatsapp:'wa',email:'em',messenger:'ms',website:'wb'};
  selectReplyTab(map[conv.ch]||'wa');
}

function selectFilter(ch){
  currentFilter=ch;
  document.querySelectorAll('.ftab').forEach(t=>t.classList.toggle('active',t.dataset.ch===ch));
  const list=conversations[ch]||conversations.all;
  // auto-select first in new list
  if(list.length){
    activeConvId=list[0].id;
    renderConvList(list);
    selectConv(list[0].id);
  }
}

function filterConvs(q){
  const list=(conversations[currentFilter]||conversations.all).filter(c=>c.name.toLowerCase().includes(q.toLowerCase())||c.snippet.toLowerCase().includes(q.toLowerCase()));
  renderConvList(list);
}

function toggleRightPanel(){
  rightPanelOpen=!rightPanelOpen;
  document.getElementById('right-panel').classList.toggle('open',rightPanelOpen);
}

// map from reply-tab key → channel key + label
const replyTabMap={
  wa:{ch:'whatsapp',label:'WhatsApp'},
  em:{ch:'email',label:'Email'},
  ms:{ch:'messenger',label:'Messenger'},
  wb:{ch:'website',label:'Website'}
};
function selectReplyTab(key){
  ['wa','em','ms','wb'].forEach(k=>document.getElementById('rt-'+k).classList.toggle('active',k===key));
  // update channel badge in header to reflect chosen reply platform
  const info=replyTabMap[key];
  if(!info) return;
  const badge=document.getElementById('chat-ch-badge');
  badge.style.background=chBgColors[info.ch]||'#6b7280';
  badge.innerHTML=chIcons[info.ch]||'';
  document.getElementById('reply-textarea').placeholder=`Type your reply via ${info.label}...`;
}

function sendMsg(){
  const ta=document.getElementById('reply-textarea');
  const txt=ta.value.trim();
  if(!txt)return;
  const msgs=document.getElementById('messages');
  const bubble=document.createElement('div');
  bubble.className='msg-bubble me';
  bubble.textContent=txt;
  msgs.appendChild(bubble);
  ta.value='';
  msgs.scrollTop=msgs.scrollHeight;
}

// ── PAGE SWITCHING ──
function showPage(page){
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  document.getElementById('page-'+page).classList.add('active');
  document.getElementById('nav-omni').classList.toggle('active',page==='omni');
  document.getElementById('nav-int').classList.toggle('active',page==='integrations');
  // update nav icon colors
  document.getElementById('nav-omni').querySelector('svg').setAttribute('stroke',page==='omni'?'#2563EB':'#6b7280');
  document.getElementById('nav-omni').querySelector('span').style.color=page==='omni'?'#2563EB':'#6b7280';
  document.getElementById('nav-int').querySelector('svg').setAttribute('stroke',page==='integrations'?'#2563EB':'#6b7280');
  document.getElementById('nav-int').querySelector('span').style.color=page==='integrations'?'#2563EB':'#6b7280';
}

// ── TOGGLE CONFIRM MODAL ──
function confirmToggle(checkbox, channelName){
  // revert optimistic toggle — wait for confirm
  checkbox.checked=!checkbox.checked;
  pendingToggle={checkbox,channelName};
  document.getElementById('modal-overlay').classList.add('open');
}
function closeModal(confirmed){
  document.getElementById('modal-overlay').classList.remove('open');
  if(confirmed && pendingToggle){
    const{checkbox}=pendingToggle;
    checkbox.checked=!checkbox.checked;
    // update status label
    const card=checkbox.closest('.int-card');
    const statusEl=card.querySelector('.int-status');
    const isNowConnected=checkbox.checked;
    statusEl.textContent=isNowConnected?'CONNECTED':'DISCONNECTED';
    statusEl.className='int-status '+(isNowConnected?'connected':'disconnected');
  }
  pendingToggle=null;
}

